// ============================================================
// ULTIMATE CONFLUENCE v5.0 | 13-Factor God-Mode Engine
// Backend Scoring: MTF EMA, VWAP, BB, SFP, FVG, MSB, ORB, Breaker, Pivots
// ============================================================
//@version=6
indicator("Ultimate 13-Factor Confluence [God-Mode]", overlay=true, max_boxes_count=300, max_lines_count=300, max_labels_count=300)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 1 — INPUTS
// ═══════════════════════════════════════════════════════════
grp_score = "🎯 The 13-Factor Engine"
i_reqScore = input.int(7, "Minimum Confluence Score (1-13)", minval=1, maxval=13, step=1, group=grp_score)
i_orbSess  = input.string("New York (0930-1000)", "ORB Session", options=["New York (0930-1000)", "London (0800-0830)", "Asian (2000-2030)", "Disabled/Crypto"], group=grp_score)

grp_core  = "⚙️ Core Logic"
i_swing   = input.int(5,     "Swing Length",                group=grp_core, minval=3)
i_atrLen  = input.int(14,    "ATR Length",                  group=grp_core)
i_atrM    = input.float(2.0, "ATR SL Multiplier",           group=grp_core, step=0.1)
i_tpM    = input.float(1.0, "TP R:R",                      group=grp_core, step=0.1)

grp_trend = "📈 Multi-Timeframe Trend"
i_tf1     = input.timeframe("240", "HTF 1 (Master Trend)",  group=grp_trend)
i_tf2     = input.timeframe("60",  "HTF 2 (Mid-Term Trend)",group=grp_trend)
i_noRepaint= input.bool(true, "No-Repaint (Use Closed HTF)",group=grp_trend)
i_emaLen  = input.int(200,   "HTF EMA Length",              group=grp_trend)
i_hullLen = input.int(25,    "Hull Baseline Length",        group=grp_trend)

grp_sfx   = "⚡ Execution Triggers"
i_ignVol  = input.bool(false, "Ignore Volume (Tick Data/Forex)", group=grp_sfx, tooltip="Check this if trading non-exchange centralized assets where volume is unreliable.")
i_volLen  = input.int(20,    "Volume Z-Score Length",       group=grp_sfx)
i_volTh   = input.float(0.8, "Volume Z-Score Threshold",    group=grp_sfx, step=0.1)
i_tmoLen  = input.int(7,     "TMO Length",                  group=grp_sfx)

grp_fib   = "📐 Fib Zone"
i_fibLow  = input.float(0.382, "Fib Low Level",             group=grp_fib, step=0.01)
i_fibHigh = input.float(0.618, "Fib High Level",            group=grp_fib, step=0.01)
i_zoneCD  = input.int(5,     "Signal Cooldown (bars)",      group=grp_fib, minval=1)

grp_liq   = "💧 Liquidity Pools"
i_eqLen   = input.int(3,      "Equal H/L Tolerance (bars)", group=grp_liq, minval=2)
i_eqTol   = input.float(0.1,  "Equal H/L ATR Tolerance",    group=grp_liq, step=0.05)
i_sweepWin= input.int(10,     "Sweep Window (bars)",        group=grp_liq, minval=3)

grp_ui    = "🎨 Visuals"
i_boxDist = input.int(8,     "Box Gap (bars)",              group=grp_ui, minval=1)
i_boxLen  = input.int(15,    "Box Width (bars)",            group=grp_ui, minval=5)
i_showD   = input.bool(true, "Show Dashboard",              group=grp_ui)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 2 — THE 12-FACTOR ENGINE (BACKGROUND CALCULATIONS)
// ═══════════════════════════════════════════════════════════

// ── Shared Tools ──
atr      = ta.atr(i_atrLen)
ema200   = ta.ema(close, i_emaLen)
baseline = ta.hma(close, i_hullLen)

// ── Factor 1: MTF Trend (4H + 1H) ──
f_get_trend(_tf) =>
    _bull = close > ta.ema(close, i_emaLen)
    _bear = close < ta.ema(close, i_emaLen)
    _resBull = i_noRepaint ? request.security(syminfo.tickerid, _tf, _bull[1], lookahead=barmerge.lookahead_on) : request.security(syminfo.tickerid, _tf, _bull)
    _resBear = i_noRepaint ? request.security(syminfo.tickerid, _tf, _bear[1], lookahead=barmerge.lookahead_on) : request.security(syminfo.tickerid, _tf, _bear)
    [_resBull, _resBear]

[tf1_bull, tf1_bear] = f_get_trend(i_tf1)
[tf2_bull, tf2_bear] = f_get_trend(i_tf2)
mtfBull = tf1_bull and tf2_bull
mtfBear = tf1_bear and tf2_bear

// ── Factor 2: Hull Baseline ──
bullHull = close > baseline
bearHull = close < baseline

// ── Factor 3: Volume Spike ──
volAvg   = ta.sma(volume, i_volLen)
volStd   = ta.stdev(volume, i_volLen)
volZ     = volStd == 0 ? 0.0 : (volume - volAvg) / volStd
volSpike = ta.ema(volZ, 3) > i_volTh
bullVol = i_ignVol ? true : volSpike
bearVol = i_ignVol ? true : volSpike

// ── Factor 4: TMO Momentum ──
osc      = ta.mom(ta.sma(ta.sma(close, i_tmoLen), i_tmoLen), i_tmoLen)
bullMom  = ta.change(osc) > 0
bearMom  = ta.change(osc) < 0

// ── Base Market Structure (Required for 5, 6, 11, 13) ──
ph = ta.pivothigh(high, i_swing, i_swing)
pl = ta.pivotlow(low,   i_swing, i_swing)
var float lastSH = na
var float lastSL = na

// Breaker Dimensions (Order Block that creates the pivot)
var float ph_high = na
var float ph_low  = na
var float pl_high = na
var float pl_low  = na

if not na(ph)
    lastSH := ph
    ph_high := high[i_swing]
    ph_low  := low[i_swing]

if not na(pl)
    lastSL := pl
    pl_high := high[i_swing]
    pl_low  := low[i_swing]

// ── Factor 5: SFP / Liquidity Sweeps ──
eqTolPts = atr * i_eqTol
prevHighN = ta.highest(high[1], i_eqLen)
prevLowN  = ta.lowest(low[1],   i_eqLen)
eqHighSweep  = math.abs(high[1] - prevHighN[1]) <= eqTolPts and high > prevHighN[1] and close < prevHighN[1]
eqLowSweep   = math.abs(low[1]  - prevLowN[1])  <= eqTolPts and low  < prevLowN[1]  and close > prevLowN[1]

swingHighSweep = not na(lastSH) and high > lastSH and close < lastSH
swingLowSweep  = not na(lastSL) and low  < lastSL and close > lastSL

prevDayHigh = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
prevDayLow  = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
sessHighSweep = not na(prevDayHigh) and high > prevDayHigh and close < prevDayHigh
sessLowSweep  = not na(prevDayLow)  and low  < prevDayLow  and close > prevDayLow

bullSweep = eqLowSweep  or swingLowSweep  or sessLowSweep
bearSweep = eqHighSweep or swingHighSweep or sessHighSweep
recentBullSweep = nz(ta.barssince(bullSweep)) <= i_sweepWin
recentBearSweep = nz(ta.barssince(bearSweep)) <= i_sweepWin

// ── Factor 6: Fib Golden Zone ──
var float fibHigh_long  = na
var float fibLow_long   = na
var float sl_long       = na
var float fibLow_short  = na
var float fibHigh_short = na
var float sl_short      = na

if not na(lastSH) and not na(lastSL)
    diff          = math.abs(lastSH - lastSL)
    fibHigh_long  := lastSH - diff * i_fibLow
    fibLow_long   := lastSH - diff * i_fibHigh
    sl_long       := lastSL - atr * i_atrM
    fibLow_short  := lastSL + diff * i_fibLow
    fibHigh_short := lastSL + diff * i_fibHigh
    sl_short      := lastSH + atr * i_atrM

longZoneTouch  = not na(fibLow_long)  and low  <= fibHigh_long  and low  >= sl_long
shortZoneTouch = not na(fibLow_short) and high >= fibLow_short  and high <= shortZoneTouch // Fixed typo in user code: shortZoneTouch was used as high <= shortZoneTouch
recentLongTouch  = nz(ta.barssince(longZoneTouch))  <= 30
recentShortTouch = nz(ta.barssince(shortZoneTouch)) <= 30

// ── Factor 7: VWAP ──
bullVWAP = close > ta.vwap
bearVWAP = close < ta.vwap

// ── Factor 8: Bollinger Bands (Midline Direction) ──
bullBB = close > ta.sma(close, 20)
bearBB = close < ta.sma(close, 20)

// ── Factor 9: Daily Pivot Points ──
prevD_Close= request.security(syminfo.tickerid, "D", close[1],lookahead=barmerge.lookahead_on)
pivotLine  = (prevDayHigh + prevDayLow + prevD_Close) / 3
bullPivot  = not na(pivotLine) and close > pivotLine
bearPivot  = not na(pivotLine) and close < pivotLine

// ── Factor 10: Fair Value Gap (FVG) ──
bullFVG = low > high[2] and close[1] > open[1]
bearFVG = high < low[2] and close[1] < open[1]
recentBullFVG = nz(ta.barssince(bullFVG)) <= i_sweepWin
recentBearFVG = nz(ta.barssince(bearFVG)) <= i_sweepWin

// ── Factor 11: CHoCH / BOS Structure ──
crossBullMSB = ta.crossover(close, nz(lastSH))
crossBearMSB = ta.crossunder(close, nz(lastSL))
bullMSB = not na(lastSH) and crossBullMSB
bearMSB = not na(lastSL) and crossBearMSB
recentBullMSB = nz(ta.barssince(bullMSB)) <= i_sweepWin
recentBearMSB = nz(ta.barssince(bearMSB)) <= i_sweepWin

// ── Factor 13: SMC Breaker Blocks (IFVG/Failed OB) ──
// A Bullish Breaker is an old shattered Swing High. A Bearish Breaker is an old shattered Swing Low.
var float bullBreakerTop = na
var float bullBreakerBot = na
var float bearBreakerTop = na
var float bearBreakerBot = na

if bullMSB
    bullBreakerTop := ph_high
    bullBreakerBot := ph_low
    bearBreakerTop := na // Invalidate opposite direction to prevent conflicting traps

if bearMSB
    bearBreakerTop := pl_high
    bearBreakerBot := pl_low
    bullBreakerTop := na

// A mitigation/touch occurs when price retraces heavily INTO the active Breaker Block.
bullBreakerTouch = not na(bullBreakerTop) and low <= bullBreakerTop and high >= bullBreakerBot and close > bullBreakerBot
bearBreakerTouch = not na(bearBreakerTop) and high >= bearBreakerBot and low <= bearBreakerTop and close < bearBreakerTop

recentBullBreaker = nz(ta.barssince(bullBreakerTouch)) <= i_sweepWin
recentBearBreaker = nz(ta.barssince(bearBreakerTouch)) <= i_sweepWin

// ── Factor 12: ORB (Opening Range Breakout) ──
s_time = i_orbSess == "New York (0930-1000)" ? "0930-1000" : i_orbSess == "London (0800-0830)" ? "0800-0830" : "2000-2030"
t_tz = i_orbSess == "New York (0930-1000)" ? "America/New_York" : i_orbSess == "London (0800-0830)" ? "Europe/London" : "Asia/Tokyo"
t_sess = time(timeframe.period, s_time, t_tz)

var float orbHigh = na
var float orbLow  = na

if i_orbSess != "Disabled/Crypto"
    if na(t_sess[1]) and not na(t_sess)
        orbHigh := high
        orbLow  := low
    else if not na(t_sess)
        orbHigh := math.max(orbHigh, high)
        orbLow  := math.min(orbLow, low)

bullORB = i_orbSess == "Disabled/Crypto" ? true : (not na(orbHigh) and close > orbHigh)
bearORB = i_orbSess == "Disabled/Crypto" ? true : (not na(orbLow)  and close < orbLow)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 3 — SCORE COMPILATION & SIGNAL GATE
// ═══════════════════════════════════════════════════════════

int longPts = 0
longPts += mtfBull ? 1 : 0
longPts += bullHull ? 1 : 0
longPts += bullVol ? 1 : 0
longPts += bullMom ? 1 : 0
longPts += recentBullSweep ? 1 : 0
longPts += recentLongTouch ? 1 : 0
longPts += bullVWAP ? 1 : 0
longPts += bullBB ? 1 : 0
longPts += bullPivot ? 1 : 0
longPts += recentBullFVG ? 1 : 0
longPts += recentBullMSB ? 1 : 0
longPts += bullORB ? 1 : 0
longPts += recentBullBreaker ? 1 : 0

int shortPts = 0
shortPts += mtfBear ? 1 : 0
shortPts += bearHull ? 1 : 0
shortPts += bearVol ? 1 : 0
shortPts += bearMom ? 1 : 0
shortPts += recentBearSweep ? 1 : 0
shortPts += recentShortTouch ? 1 : 0
shortPts += bearVWAP ? 1 : 0
shortPts += bearBB ? 1 : 0
shortPts += bearPivot ? 1 : 0
shortPts += recentBearFVG ? 1 : 0
shortPts += recentBearMSB ? 1 : 0
shortPts += bearORB ? 1 : 0
shortPts += recentBearBreaker ? 1 : 0

// The Signal must cross the Baseline to trigger while possessing a highly confident score!
crossBullBL = ta.crossover(close, baseline)
crossBearBL = ta.crossunder(close, baseline)
longCond  = (longPts >= i_reqScore)  and crossBullBL
shortCond = (shortPts >= i_reqScore) and crossBearBL

var int lastLongBar  = na
var int lastShortBar = na

isNewLong  = longCond  and (na(lastLongBar)  or bar_index - lastLongBar  > i_zoneCD + i_boxDist + i_boxLen)
isNewShort = shortCond and (na(lastShortBar) or bar_index - lastShortBar > i_zoneCD + i_boxDist + i_boxLen)

if isNewLong
    lastLongBar  := bar_index
if isNewShort
    lastShortBar := bar_index

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 4 — SIGNAL ARROWS & TRACKERS
// ═══════════════════════════════════════════════════════════

plotshape(isNewLong,  "Long Breakout",  shape.triangleup,   location.belowbar, color.lime, size=size.normal)
plotshape(isNewShort, "Short Breakout", shape.triangledown, location.abovebar, color.red,  size=size.normal)

var int   tState    = 0 // 1 = Long, -1 = Short, 0 = Flat
var float tSL       = na
var float tTP       = na
var int   tEntryBar = na

if isNewLong
    int   bSig  = bar_index
    int   bL    = bSig + i_boxDist
    int   bR    = bL   + i_boxLen
    float eLvl  = close
    float slLvl = not na(sl_long) ? sl_long : eLvl - atr * i_atrM
    float risk  = math.abs(eLvl - slLvl)
    float tp    = eLvl + risk * i_tpM

    line.new(bSig, eLvl, bL, eLvl, color=color.new(color.gray, 50), style=line.style_dashed, width=1)
    
    // Core Risk / TP visuals
    box.new(bL, eLvl,  bR, slLvl, border_color=color.new(color.red,  40), bgcolor=color.new(color.red,  88), text="SL",  text_color=color.new(color.red,  10), text_size=size.tiny, text_halign=text.align_right)
    line.new(bL, eLvl, bR, eLvl,  color=color.new(color.white, 20), width=2)
    box.new(bL, tp, bR, eLvl, border_color=color.new(color.lime,   40), bgcolor=color.new(color.lime,   90), text="TP", text_color=color.new(color.lime,   10), text_size=size.tiny, text_halign=text.align_right)

    label.new(bSig, slLvl - atr * 1.5,
              "LONG 🔥 [" + str.tostring(longPts) + "/13]\nEntry: " + str.tostring(eLvl, format.mintick) +
              "\nSL:    " + str.tostring(slLvl, format.mintick) +
              "\nTP:   "  + str.tostring(tp,   format.mintick),
              style=label.style_label_up, color=color.new(color.black, 10), textcolor=color.white, textalign=text.align_left, size=size.small)

    tState    := 1
    tSL       := slLvl
    tTP       := tp
    tEntryBar := bar_index

if isNewShort
    int   bSig  = bar_index
    int   bL    = bSig + i_boxDist
    int   bR    = bL   + i_boxLen
    float eLvl  = close
    float slLvl = not na(sl_short) ? sl_short : eLvl + atr * i_atrM
    float risk  = math.abs(slLvl - eLvl)
    float tp    = eLvl - risk * i_tpM

    line.new(bSig, eLvl, bL, eLvl, color=color.new(color.gray, 50), style=line.style_dashed, width=1)
    
    // Core Risk / TP visuals
    box.new(bL, slLvl, bR, eLvl,  border_color=color.new(color.red,    40), bgcolor=color.new(color.red,    88), text="SL",  text_color=color.new(color.red,    10), text_size=size.tiny, text_halign=text.align_right)
    line.new(bL, eLvl, bR, eLvl,  color=color.new(color.white, 20), width=2)
    box.new(bL, eLvl,  bR, tp,   border_color=color.new(color.lime, 40), bgcolor=color.new(color.lime, 90), text="TP", text_color=color.new(color.lime, 10), text_size=size.tiny, text_halign=text.align_right)

    label.new(bSig, slLvl + atr * 1.5,
              "SHORT 🔥 [" + str.tostring(shortPts) + "/13]\nEntry: " + str.tostring(eLvl, format.mintick) +
              "\nSL:    " + str.tostring(slLvl, format.mintick) +
              "\nTP:   "  + str.tostring(tp,   format.mintick),
              style=label.style_label_down, color=color.new(color.black, 10), textcolor=color.white, textalign=text.align_left, size=size.small)

    tState    := -1
    tSL       := slLvl
    tTP       := tp
    tEntryBar := bar_index

// ── Active Trade Tracker ──────────────────────────────────
if tState == 1 and bar_index > tEntryBar
    if high >= tTP
        label.new(bar_index, tTP + atr * 2.5, "✅ WIN", style=label.style_label_down, color=color.new(color.lime, 40), textcolor=color.black, size=size.small)
        tState := 0 // Reset
    else if low <= tSL
        label.new(bar_index, tSL - atr * 2.5, "❌ LOSS", style=label.style_label_up, color=color.new(color.red, 40), textcolor=color.white, size=size.small)
        tState := 0

if tState == -1 and bar_index > tEntryBar
    if low <= tTP
        label.new(bar_index, tTP - atr * 2.5, "✅ WIN", style=label.style_label_up, color=color.new(color.lime, 40), textcolor=color.black, size=size.small)
        tState := 0
    else if high >= tSL
        label.new(bar_index, tSL + atr * 2.5, "❌ LOSS", style=label.style_label_down, color=color.new(color.red, 40), textcolor=color.white, size=size.small)
        tState := 0

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 5 — DASHBOARD
// ═══════════════════════════════════════════════════════════

var table mainDash = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 85), border_color=color.new(color.gray, 80), border_width=1)

if barstate.islast and i_showD
    table.cell(mainDash, 0, 0, "🔥 CONFLUENCE ENGINE", text_color=color.white, text_size=size.small, bgcolor=color.new(color.blue, 60))
    table.cell(mainDash, 1, 0, "v5.0 GOD-MODE", text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.blue, 60))
    
    table.cell(mainDash, 0, 1, "Long Score", text_color=color.white, text_size=size.small)
    table.cell(mainDash, 1, 1, str.tostring(longPts) + " / 13", text_color=longPts >= i_reqScore ? color.lime : color.gray, text_size=size.small)
    
    table.cell(mainDash, 0, 2, "Short Score", text_color=color.white, text_size=size.small)
    table.cell(mainDash, 1, 2, str.tostring(shortPts) + " / 13", text_color=shortPts >= i_reqScore ? color.red : color.gray, text_size=size.small)
    
    table.cell(mainDash, 0, 3, "FVG Status", text_color=color.white, text_size=size.tiny)
    table.cell(mainDash, 1, 3, recentBullFVG ? "BULL" : recentBearFVG ? "BEAR" : "-", text_color=recentBullFVG ? color.lime : recentBearFVG ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(mainDash, 0, 4, "CHoCH / BOS", text_color=color.white, text_size=size.tiny)
    table.cell(mainDash, 1, 4, recentBullMSB ? "BULL BREAK" : recentBearMSB ? "BEAR BREAK" : "-", text_color=recentBullMSB ? color.lime : recentBearMSB ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(mainDash, 0, 5, "VWAP", text_color=color.white, text_size=size.tiny)
    table.cell(mainDash, 1, 5, bullVWAP ? "ABOVE" : bearVWAP ? "BELOW" : "-", text_color=bullVWAP ? color.lime : bearVWAP ? color.red : color.gray, text_size=size.tiny)
    
    s_label = i_orbSess == "New York (0930-1000)" ? "ORB (NY)" : i_orbSess == "London (0800-0830)" ? "ORB (LON)" : i_orbSess == "Asian (2000-2030)" ? "ORB (ASIA)" : "ORB"
    s_val = i_orbSess == "Disabled/Crypto" ? "DISABLED" : bullORB ? "BROKEN UP" : bearORB ? "BROKEN DOWN" : "INSIDE"
    table.cell(mainDash, 0, 6, s_label, text_color=color.white, text_size=size.tiny)
    table.cell(mainDash, 1, 6, s_val, text_color=i_orbSess == "Disabled/Crypto" ? color.gray : bullORB ? color.lime : bearORB ? color.red : color.gray, text_size=size.tiny)

    table.cell(mainDash, 0, 7, "Breaker Block", text_color=color.white, text_size=size.tiny)
    table.cell(mainDash, 1, 7, recentBullBreaker ? "BULL MITIGATED" : recentBearBreaker ? "BEAR MITIGATED" : "-", text_color=recentBullBreaker ? color.lime : recentBearBreaker ? color.red : color.gray, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 6 — ALERTS
// ═══════════════════════════════════════════════════════════

if isNewLong
    alert("LONG — 12-Factor Confirmed | Entry: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if isNewShort
    alert("SHORT — 12-Factor Confirmed | Entry: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
