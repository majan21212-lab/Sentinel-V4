//@version=6
strategy("Alpha-Gate X Strategy (AGX)", "AGX Strategy", overlay=true, 
     initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=2, 
     commission_type=strategy.commission.percent, commission_value=0.01,
     max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// =============================================================================
// ▶ SECTION 1: UNIFIED MASTER INPUTS
// =============================================================================

grp_symbol  = "🌍 Symbol-Specific Presets"
i_pipUnit   = input.float(1.0,   "Pip/Tick Unit Value", minval=0.0001, step=0.1, group=grp_symbol, tooltip="BTCUSD=1.0, GOLDUSD=0.1, Forex=0.0001")
i_tp1Pips   = input.float(25.0,  "TP1 Distance (Pips)", minval=1.0, step=1.0, group=grp_symbol)
i_tp2Pips   = input.float(50.0,  "TP2 Distance (Pips)", minval=1.0, step=1.0, group=grp_symbol)

grp_core    = "⚙️ Core Engine Settings"
i_swingLen  = input.int(10,      "Swing Lookback (bars)", minval=3, group=grp_core)
i_atrLen    = input.int(14,      "ATR Length", group=grp_core)
i_sensitivity = input.int(3,     "Signal Sensitivity (1-5)", minval=1, maxval=5, group=grp_core, tooltip="Higher = Fewer, more reliable signals.")

grp_smc     = "🔷 SMC & CRT Logic"
i_useCRT    = input.bool(true,   "Enable CRT (Candle Range Theory)", group=grp_smc)
i_crtBars   = input.int(5,       "CRT Lookback Bars", minval=2, maxval=10, group=grp_smc)
i_useSMC    = input.bool(true,   "Use SMC Structure (BOS/CHoCH)", group=grp_smc)

grp_viz     = "🎨 Visuals & Aesthetics"
i_boxOffset = input.int(5,       "Box Offset (bars)", minval=0, group=grp_viz)
i_boxWidth  = input.int(12,      "Box Width (bars)", minval=5, group=grp_viz)
i_showDash  = input.bool(true,   "Show Performance Dashboard", group=grp_viz)

// =============================================================================
// ▶ SECTION 2: CORE CALCULATIONS
// =============================================================================

atr = ta.atr(i_atrLen)
pip = i_pipUnit

// ── TREND DETECTION (SWING STRUCTURE) ──
ph = ta.pivothigh(high, i_swingLen, i_swingLen)
pl = ta.pivotlow(low,   i_swingLen, i_swingLen)

var float lastSH = na
var float lastSL = na
var int   lastSHBar = na
var int   lastSLBar = na

if not na(ph)
    lastSH := ph
    lastSHBar := bar_index[i_swingLen]
if not na(pl)
    lastSL := pl
    lastSLBar := bar_index[i_swingLen]

// Trend Classification
var int trendState = 0 // 1: Uptrend, -1: Downtrend, 0: Neutral
if not na(lastSH) and not na(lastSL)
    if high > lastSH and low > lastSL
        trendState := 1
    else if low < lastSL and high < lastSH
        trendState := -1
    else
        trendState := 0

// ── MOMENTUM ENGINE ──
bodySize = math.abs(close - open)
avgBody  = ta.sma(bodySize, 20)
isMomentum = bodySize > avgBody * 1.5

// ── CRT (CANDLE RANGE THEORY) ──
crtHigh = ta.highest(high[1], i_crtBars)
crtLow  = ta.lowest(low[1],   i_crtBars)
isCRTBreakUp = i_useCRT and close > crtHigh and bodySize > (crtHigh - crtLow) * 0.5
isCRTBreakDn = i_useCRT and close < crtLow  and bodySize > (crtHigh - crtLow) * 0.5

// ── LIQUIDITY/VOLUME PROXY ──
volZ = (volume - ta.sma(volume, 20)) / ta.stdev(volume, 20)
highLiquidity = volZ > 1.0

// =============================================================================
// ▶ SECTION 3: SIGNAL CONFLUENCE
// =============================================================================

bullConfluence = 0
bullConfluence += (trendState == 1 ? 1 : 0)
bullConfluence += (isMomentum ? 1 : 0)
bullConfluence += (isCRTBreakUp ? 1 : 0)
bullConfluence += (highLiquidity ? 1 : 0)
bullConfluence += (close > ta.ema(close, 200) ? 1 : 0)

bearConfluence = 0
bearConfluence += (trendState == -1 ? 1 : 0)
bearConfluence += (isMomentum ? 1 : 0)
bearConfluence += (isCRTBreakDn ? 1 : 0)
bearConfluence += (highLiquidity ? 1 : 0)
bearConfluence += (close < ta.ema(close, 200) ? 1 : 0)

isBullSignal = bullConfluence >= i_sensitivity
isBearSignal = bearConfluence >= i_sensitivity

// NO-HIT-SL GUARDRAIL (Avoid entries if price is already near a recent volatility peak)
guardrailLong = low > (close - atr * 1.0)
guardrailShort = high < (close + atr * 1.0)

longTrigger  = isBullSignal and guardrailLong
shortTrigger = isBearSignal and guardrailShort

// =============================================================================
// ▶ SECTION 4: TRADE MANAGEMENT & VISUALS
// =============================================================================

var int lastSignalBar = 0
canSignal = (bar_index - lastSignalBar) > 10

if longTrigger and canSignal
    float eLvl  = close
    float slLvl = lastSL < eLvl ? lastSL - (5 * pip) : eLvl - (atr * 2)
    float tp1Lvl = eLvl + (i_tp1Pips * pip)
    float tp2Lvl = eLvl + (i_tp2Pips * pip)
    
    // Strategy Execution
    strategy.entry("AGX Long", strategy.long, comment="Entry: " + str.tostring(eLvl, format.mintick))
    strategy.exit("TP1/SL", "AGX Long", qty_percent=50, limit=tp1Lvl, stop=slLvl, comment_loss="SL", comment_profit="TP1")
    strategy.exit("TP2/SL", "AGX Long", qty_percent=100, limit=tp2Lvl, stop=slLvl, comment_loss="SL", comment_profit="TP2")
    
    // Visual Boxes
    int bL = bar_index + i_boxOffset
    int bR = bL + i_boxWidth
    
    line.new(bar_index, eLvl, bL, eLvl, color=color.new(color.lime, 50), style=line.style_dashed)
    box.new(bL, tp2Lvl, bR, tp1Lvl, border_color=color.new(color.lime, 50), bgcolor=color.new(color.lime, 90), text="TP2", text_size=size.tiny, text_color=color.lime)
    box.new(bL, tp1Lvl, bR, eLvl,   border_color=color.new(color.teal, 50), bgcolor=color.new(color.teal, 90), text="TP1", text_size=size.tiny, text_color=color.teal)
    box.new(bL, eLvl,   bR, slLvl,  border_color=color.new(color.red,  50), bgcolor=color.new(color.red,  90), text="SL",  text_size=size.tiny, text_color=color.red)
    
    label.new(bar_index, low - atr, "AGX BUY 🔥\nScore: " + str.tostring(bullConfluence) + "/5", style=label.style_label_up, color=color.black, textcolor=color.white, size=size.small)
    
    lastSignalBar := bar_index
    alert("AGX Long Entry at " + str.tostring(eLvl), alert.freq_once_per_bar)

if shortTrigger and canSignal
    float eLvl  = close
    float slLvl = lastSH > eLvl ? lastSH + (5 * pip) : eLvl + (atr * 2)
    float tp1Lvl = eLvl - (i_tp1Pips * pip)
    float tp2Lvl = eLvl - (i_tp2Pips * pip)
    
    // Strategy Execution
    strategy.entry("AGX Short", strategy.short, comment="Entry: " + str.tostring(eLvl, format.mintick))
    strategy.exit("TP1/SL", "AGX Short", qty_percent=50, limit=tp1Lvl, stop=slLvl, comment_loss="SL", comment_profit="TP1")
    strategy.exit("TP2/SL", "AGX Short", qty_percent=100, limit=tp2Lvl, stop=slLvl, comment_loss="SL", comment_profit="TP2")
    
    // Visual Boxes
    int bL = bar_index + i_boxOffset
    int bR = bL + i_boxWidth
    
    line.new(bar_index, eLvl, bL, eLvl, color=color.new(color.red, 50), style=line.style_dashed)
    box.new(bL, slLvl,  bR, eLvl,   border_color=color.new(color.red,  50), bgcolor=color.new(color.red,  90), text="SL",  text_size=size.tiny, text_color=color.red)
    box.new(bL, eLvl,   bR, tp1Lvl, border_color=color.new(color.teal, 50), bgcolor=color.new(color.teal, 90), text="TP1", text_size=size.tiny, text_color=color.teal)
    box.new(bL, tp1Lvl, bR, tp2Lvl, border_color=color.new(color.lime, 50), bgcolor=color.new(color.lime, 90), text="TP2", text_size=size.tiny, text_color=color.lime)
    
    label.new(bar_index, high + atr, "AGX SELL 🔥\nScore: " + str.tostring(bearConfluence) + "/5", style=label.style_label_down, color=color.black, textcolor=color.white, size=size.small)
    
    lastSignalBar := bar_index
    alert("AGX Short Entry at " + str.tostring(eLvl), alert.freq_once_per_bar)

// =============================================================================
// ▶ SECTION 5: PERFORMANCE DASHBOARD
// =============================================================================

var table dash = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)

if barstate.islast and i_showDash
    table.cell(dash, 0, 0, "AGX STATUS", text_color=color.white, bgcolor=color.new(color.blue, 60))
    table.cell(dash, 1, 0, trendState == 1 ? "UPTREND" : trendState == -1 ? "DOWNTREND" : "NEUTRAL", text_color=trendState == 1 ? color.lime : trendState == -1 ? color.red : color.gray)
    
    table.cell(dash, 0, 1, "Win Rate", text_color=color.gray)
    table.cell(dash, 1, 1, str.format("{0,number,#.#}%", strategy.wintrades / math.max(1, strategy.closedtrades) * 100), text_color=color.white)
    
    table.cell(dash, 0, 2, "Net Profit", text_color=color.gray)
    table.cell(dash, 1, 2, str.tostring(strategy.netprofit, "###,###.##"), text_color=strategy.netprofit >= 0 ? color.lime : color.red)
    
    table.cell(dash, 0, 3, "Drawdown", text_color=color.gray)
    table.cell(dash, 1, 3, str.format("{0,number,#.#}%", strategy.max_drawdown / strategy.initial_capital * 100), text_color=color.orange)

// =============================================================================
// ▶ SECTION 6: DIAGNOSTICS & PLOTS
// =============================================================================

plot(ta.ema(close, 200), "HTF Trend EMA", color=color.new(color.white, 70), linewidth=1)
plotshape(isMomentum and trendState == 1, "Bull Momentum", shape.circle, location.belowbar, color.new(color.lime, 40), size=size.tiny)
plotshape(isMomentum and trendState == -1, "Bear Momentum", shape.circle, location.abovebar, color.new(color.red, 40), size=size.tiny)

// Visualizing CRT Ranges
var line crtLine = na
if isCRTBreakUp or isCRTBreakDn
    line.delete(crtLine)
    crtLine := line.new(bar_index - i_crtBars, crtHigh, bar_index, crtHigh, color=color.new(color.gray, 80), style=line.style_dotted)
