// © Ultimate Master Confluence MTF v6.1

//@version=5
indicator("Ultimate Master Confluence MTF [v6.1]", overlay=true, max_boxes_count=100, max_lines_count=100, max_labels_count=200)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 1 — INPUTS
// ═══════════════════════════════════════════════════════════

grp_mtf   = "🌍 Multi-Timeframe Trend Alignment"
i_htf1    = input.timeframe("240",  "Higher TF 1 (Macro Trend)",    group=grp_mtf, tooltip="Default: 4H. Sets the macro trend direction.")
i_htf2    = input.timeframe("60",   "Higher TF 2 (Intermediate)",   group=grp_mtf, tooltip="Default: 1H. Confirms intermediate trend.")
i_htfEma1 = input.int(200,  "Macro EMA Length (HTF1)",              group=grp_mtf)
i_htfEma2 = input.int(50,   "Intermediate EMA Length (HTF2)",       group=grp_mtf)
i_htfHull = input.int(25,   "Hull Baseline Length (HTF2)",          group=grp_mtf)
i_reqMTF  = input.bool(true, "Require MTF Alignment (Recommended)", group=grp_mtf, tooltip="When ON, signals fire only when ALL timeframes agree on direction.")

grp_core  = "⚙️ Core Settings (Execution Timeframe)"
i_swing   = input.int(5,     "Structure Swing Length",     group=grp_core, minval=3, maxval=50)
i_atrLen  = input.int(14,    "ATR Length (Risk Mgt)",      group=grp_core)
i_atrM    = input.float(2.0, "ATR SL Multiplier",          group=grp_core, step=0.1)
i_tpM1    = input.float(1.0, "TP1 Reward Ratio",           group=grp_core, step=0.1)
i_tpM2    = input.float(2.0, "TP2 Reward Ratio",           group=grp_core, step=0.1)

grp_trend = "📈 Execution Timeframe Trend"
i_emaLen  = input.int(200,   "Execution EMA Length",       group=grp_trend)
i_hullLen = input.int(25,    "Hull Baseline Length",       group=grp_trend)

grp_sfx   = "⚡ Execution Triggers (Volume & Mom & Liq)"
i_reqVol  = input.bool(false, "Require Volume Spike (Filter)", group=grp_sfx)
i_reqMom  = input.bool(true,  "Require TMO Momentum (Filter)", group=grp_sfx)
i_reqLiq  = input.bool(true,  "Require Liquidity Sweep (SMC)", group=grp_sfx)
i_volLen  = input.int(20,    "Volume Z-Score Length",      group=grp_sfx)
i_volTh   = input.float(1.2, "Volume Z-Score Threshold",   group=grp_sfx, step=0.1)
i_tmoLen  = input.int(7,     "TMO Momentum Length",        group=grp_sfx)
i_tmoTh   = input.float(0.5, "TMO Min Change Threshold",   group=grp_sfx, step=0.1, tooltip="Filters tiny momentum changes. Higher = less noise.")

grp_struct = "🏗️ Structure Settings"
i_pivotMax = input.int(100,  "Max Pivot Staleness (bars)",  group=grp_struct, minval=20, maxval=500, tooltip="Fib zones from pivots older than this are ignored.")
i_touchWin = input.int(30,   "Zone Touch Memory (bars)",    group=grp_struct, minval=5, maxval=60)
i_sweepWin = input.int(15,   "Liquidity Sweep Memory (bars)", group=grp_struct, minval=3, maxval=30)
i_volWin   = input.int(8,    "Volume Spike Memory (bars)",  group=grp_struct, minval=2, maxval=20)

grp_ui    = "🎨 Visuals"
i_boxDist = input.int(12,    "Box Distance from Candle",   group=grp_ui, minval=1)
i_boxLen  = input.int(15,    "Box Visual Length",          group=grp_ui, minval=5)
i_showF   = input.bool(true, "Draw Golden Fib Zones",      group=grp_ui)
i_showD   = input.bool(true, "Show Dashboard",             group=grp_ui)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 2 — MULTI-TIMEFRAME TREND ENGINE (Anti-Repaint)
// ═══════════════════════════════════════════════════════════

// --- HTF1 (Macro — e.g. 4H): EMA200 trend direction ---
htf1_ema_val  = request.security(syminfo.tickerid, i_htf1, ta.ema(close, i_htfEma1), lookahead=barmerge.lookahead_off)
htf1_close_c  = request.security(syminfo.tickerid, i_htf1, close[1],                 lookahead=barmerge.lookahead_off)

htf1_bull = not na(htf1_close_c) and not na(htf1_ema_val) and htf1_close_c > htf1_ema_val
htf1_bear = not na(htf1_close_c) and not na(htf1_ema_val) and htf1_close_c < htf1_ema_val

// --- HTF2 (Intermediate — e.g. 1H): EMA50 + Hull MA direction ---
htf2_ema_val   = request.security(syminfo.tickerid, i_htf2, ta.ema(close, i_htfEma2),       lookahead=barmerge.lookahead_off)
htf2_hull_val  = request.security(syminfo.tickerid, i_htf2, ta.hma(close, i_htfHull),       lookahead=barmerge.lookahead_off)
htf2_hull_p    = request.security(syminfo.tickerid, i_htf2, ta.hma(close, i_htfHull)[1],    lookahead=barmerge.lookahead_off)
htf2_close_c   = request.security(syminfo.tickerid, i_htf2, close[1],                       lookahead=barmerge.lookahead_off)

htf2_hull_up   = not na(htf2_hull_val) and not na(htf2_hull_p) and htf2_hull_val > htf2_hull_p
htf2_hull_dn   = not na(htf2_hull_val) and not na(htf2_hull_p) and htf2_hull_val < htf2_hull_p

htf2_bull = not na(htf2_close_c) and not na(htf2_ema_val) and htf2_close_c > htf2_ema_val and htf2_hull_up
htf2_bear = not na(htf2_close_c) and not na(htf2_ema_val) and htf2_close_c < htf2_ema_val and htf2_hull_dn

// --- Combined MTF Verdict ---
mtf_bullish = htf1_bull and htf2_bull
mtf_bearish = htf1_bear and htf2_bear

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 3 — EXECUTION TIMEFRAME CORE INDICATORS
// ═══════════════════════════════════════════════════════════

atr       = ta.atr(i_atrLen)
ema200    = ta.ema(close, i_emaLen)
baseline  = ta.hma(close, i_hullLen)

// --- SFX Volume Force Z-Score ---
volAvg    = ta.sma(volume, i_volLen)
volStd    = ta.stdev(volume, i_volLen)
volZ      = volStd == 0 ? 0.0 : (volume - volAvg) / volStd
volForce  = ta.ema(volZ, 3)
volSpike  = volForce > i_volTh

// --- TradeIQ TMO (True Momentum Oscillator) ---
osc       = ta.mom(ta.sma(ta.sma(close, i_tmoLen), i_tmoLen), i_tmoLen)
oscChg    = ta.change(osc)
bullMom   = oscChg >  i_tmoTh
bearMom   = oscChg < -i_tmoTh

// --- Execution TF trend filter ---
localBull = close > ema200
localBear = close < ema200

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 4 — MARKET STRUCTURE & GOLDEN FIB ZONE
// ═══════════════════════════════════════════════════════════

ph = ta.pivothigh(high, i_swing, i_swing)
pl = ta.pivotlow(low,   i_swing, i_swing)

var float lastSH      = na
var float lastSL      = na
var int   lastSH_bar  = 0
var int   lastSL_bar  = 0

if not na(ph)
    lastSH     := ph
    lastSH_bar := bar_index - i_swing

if not na(pl)
    lastSL     := pl
    lastSL_bar := bar_index - i_swing

// --- Staleness check: pivots must be recent ---
pivotAge_SH  = lastSH_bar == 0 ? 9999 : (bar_index - lastSH_bar)
pivotAge_SL  = lastSL_bar == 0 ? 9999 : (bar_index - lastSL_bar)
pivotsFresh  = pivotAge_SH <= i_pivotMax and pivotAge_SL <= i_pivotMax

// --- Track which pivot came last ---
var bool lastPivotWasHigh = false
if not na(ph)
    lastPivotWasHigh := true
if not na(pl)
    lastPivotWasHigh := false

// --- Fib Zones (geometric levels only — SL at signal time) ---
var float f_05_long    = na
var float f_0618_long  = na
var float f_05_short   = na
var float f_0618_short = na

if not na(lastSH) and not na(lastSL) and pivotsFresh
    diff = math.abs(lastSH - lastSL)
    f_05_long    := lastSH - (diff * 0.5)
    f_0618_long  := lastSH - (diff * 0.618)
    f_05_short   := lastSL + (diff * 0.5)
    f_0618_short := lastSL + (diff * 0.618)
else if not pivotsFresh
    f_05_long    := na
    f_0618_long  := na
    f_05_short   := na
    f_0618_short := na

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 5 — CONFLUENCE ENGINE
// ═══════════════════════════════════════════════════════════

// --- SL computed NOW with current ATR (not at pivot time) ---
currentSL_long  = not na(lastSL) ? lastSL - (atr * i_atrM) : na
currentSL_short = not na(lastSH) ? lastSH + (atr * i_atrM) : na

// --- Zone Touch (price tapped golden zone without hitting SL) ---
longZoneTouch  = not na(f_05_long)  and not na(currentSL_long)  and low  <= f_05_long  and low  >= currentSL_long
shortZoneTouch = not na(f_05_short) and not na(currentSL_short) and high >= f_05_short and high <= currentSL_short

// --- Recency checks (9999 fallback = "never happened" → false) ---
barsSinceLZT = ta.barssince(longZoneTouch)
barsSinceSZT = ta.barssince(shortZoneTouch)
barsSinceVS  = ta.barssince(volSpike)

recentLongTouch  = not na(barsSinceLZT) and barsSinceLZT <= i_touchWin
recentShortTouch = not na(barsSinceSZT) and barsSinceSZT <= i_touchWin
recentVolSpike   = not na(barsSinceVS)  and barsSinceVS  <= i_volWin

// --- Liquidity Sweep Memory ---
bullSweep = not na(lastSL) and low < lastSL  and close > lastSL
bearSweep = not na(lastSH) and high > lastSH and close < lastSH

barsSinceBullSw = ta.barssince(bullSweep)
barsSinceBearSw = ta.barssince(bearSweep)

recentBullSweep = not na(barsSinceBullSw) and barsSinceBullSw <= i_sweepWin
recentBearSweep = not na(barsSinceBearSw) and barsSinceBearSw <= i_sweepWin

// --- Hull Baseline Breakout (execution trigger) ---
isLongBreakout  = ta.crossover(close, baseline)
isShortBreakout = ta.crossunder(close, baseline)

// ─── FINAL CONFLUENCE CONDITIONS ───

// Step 1: Local timeframe basic conditions
bool localLongOK  = localBull and recentLongTouch and isLongBreakout
bool localShortOK = localBear and recentShortTouch and isShortBreakout

// Step 2: Apply optional filters
if i_reqMom
    localLongOK  := localLongOK  and bullMom
    localShortOK := localShortOK and bearMom
if i_reqVol
    localLongOK  := localLongOK  and recentVolSpike
    localShortOK := localShortOK and recentVolSpike
if i_reqLiq
    localLongOK  := localLongOK  and recentBullSweep
    localShortOK := localShortOK and recentBearSweep

// Step 3: Directional Fib validation (swing structure must make sense)
fibValidLong  = not na(lastSH) and not na(lastSL) and lastSH > lastSL and pivotsFresh
fibValidShort = not na(lastSH) and not na(lastSL) and lastSH > lastSL and pivotsFresh

// Step 4: COMBINE with MTF alignment
bool longCond  = localLongOK  and fibValidLong  and (not i_reqMTF or mtf_bullish)
bool shortCond = localShortOK and fibValidShort and (not i_reqMTF or mtf_bearish)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 6 — SIGNALS & CLEAN VISUALS
// ═══════════════════════════════════════════════════════════

// --- Signal cooldown (prevents overlapping boxes) ---
var int lastLongBar  = 0
var int lastShortBar = 0
int cooldown = i_boxDist + i_boxLen + 2

bool isNewLong  = longCond  and (lastLongBar  == 0 or bar_index > lastLongBar  + cooldown)
bool isNewShort = shortCond and (lastShortBar == 0 or bar_index > lastShortBar + cooldown)

if isNewLong
    lastLongBar := bar_index
if isNewShort
    lastShortBar := bar_index

// --- Entry Arrows ---
plotshape(isNewLong,  "Long Signal",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.normal)
plotshape(isNewShort, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red, 0),  size=size.normal)

// --- Visual Liquidity Sweeps ---
if bullSweep
    label.new(bar_index, low - (atr * 0.5), "💧 LIQ", color=color.new(color.black, 100), textcolor=color.aqua,   style=label.style_label_up,   size=size.tiny)
if bearSweep
    label.new(bar_index, high + (atr * 0.5), "💧 LIQ", color=color.new(color.black, 100), textcolor=color.orange, style=label.style_label_down, size=size.tiny)

// ─── FLOATING SIGNAL BOXES (LONG) ───
if isNewLong
    float slL  = currentSL_long
    float dr   = math.abs(close - slL)
    float tp1  = close + (dr * i_tpM1)
    float tp2  = close + (dr * i_tpM2)

    string mtfTag  = i_reqMTF ? " [MTF✓]" : ""
    string lblText = "⚡ CONFLUENCE LONG" + mtfTag + "\n" +
                     "Entry: " + str.tostring(close, format.mintick) + "\n" +
                     "SL: "    + str.tostring(slL,   format.mintick) + "\n" +
                     "TP1: ("  + str.tostring(i_tpM1) + "R) " + str.tostring(tp1, format.mintick) + "\n" +
                     "TP2: ("  + str.tostring(i_tpM2) + "R) " + str.tostring(tp2, format.mintick)

    label.new(bar_index, low - atr * 2, lblText, color=color.white, style=label.style_label_up, textcolor=color.black, textalign=text.align_left, size=size.small)

    int st = bar_index + i_boxDist
    int en = st + i_boxLen

    line.new(bar_index, close, st, close, color=color.new(color.gray, 50), style=line.style_dashed, width=1)
    line.new(st, close, en, close, color=color.new(color.gray, 0),  style=line.style_solid)
    line.new(st, tp1,   en, tp1,   color=color.new(color.lime, 0),  style=line.style_solid)
    line.new(st, tp2,   en, tp2,   color=color.new(color.lime, 0),  style=line.style_solid)
    line.new(st, slL,   en, slL,   color=color.new(color.red,  0),  style=line.style_solid)

    box.new(st, close, en, tp2, border_color=na, bgcolor=color.new(color.lime, 90))
    box.new(st, close, en, slL, border_color=na, bgcolor=color.new(color.red,  90))

// ─── FLOATING SIGNAL BOXES (SHORT) ───
if isNewShort
    float slS  = currentSL_short
    float dr   = math.abs(slS - close)
    float tp1  = close - (dr * i_tpM1)
    float tp2  = close - (dr * i_tpM2)

    string mtfTag  = i_reqMTF ? " [MTF✓]" : ""
    string lblText = "⚡ CONFLUENCE SHORT" + mtfTag + "\n" +
                     "Entry: " + str.tostring(close, format.mintick) + "\n" +
                     "SL: "    + str.tostring(slS,   format.mintick) + "\n" +
                     "TP1: ("  + str.tostring(i_tpM1) + "R) " + str.tostring(tp1, format.mintick) + "\n" +
                     "TP2: ("  + str.tostring(i_tpM2) + "R) " + str.tostring(tp2, format.mintick)

    label.new(bar_index, high + atr * 2, lblText, color=color.white, style=label.style_label_down, textcolor=color.black, textalign=text.align_left, size=size.small)

    int st = bar_index + i_boxDist
    int en = st + i_boxLen

    line.new(bar_index, close, st, close, color=color.new(color.gray, 50), style=line.style_dashed, width=1)
    line.new(st, close, en, close, color=color.new(color.gray, 0),  style=line.style_solid)
    line.new(st, tp1,   en, tp1,   color=color.new(color.lime, 0),  style=line.style_solid)
    line.new(st, tp2,   en, tp2,   color=color.new(color.lime, 0),  style=line.style_solid)
    line.new(st, slS,   en, slS,   color=color.new(color.red,  0),  style=line.style_solid)

    box.new(st, close, en, slS, border_color=na, bgcolor=color.new(color.red,  90))
    box.new(st, close, en, tp2, border_color=na, bgcolor=color.new(color.lime, 90))

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 7 — HUD DASHBOARD & AESTHETICS
// ═══════════════════════════════════════════════════════════

// --- Trend Overlays ---
plot(ema200,   "EMA Macro Trend",  color=color.new(color.white, 50), linewidth=2)
plot(baseline, "Hull Baseline",    color=color.new(color.blue,  50), linewidth=1)

// --- Dynamic Fib Lines (drawn on last bar) ---
var line  l_50     = na
var line  l_61     = na
var label lbl_50   = na
var label lbl_61   = na
var label lbl_50_s = na
var label lbl_61_s = na

if i_showF and barstate.islast
    line.delete(l_50)
    line.delete(l_61)
    label.delete(lbl_50)
    label.delete(lbl_61)
    label.delete(lbl_50_s)
    label.delete(lbl_61_s)

    if localBull and not na(f_05_long)
        l_50   := line.new(bar_index - 30, f_05_long,   bar_index + 10, f_05_long,   color=color.new(color.lime,  50), width=1, style=line.style_dashed)
        l_61   := line.new(bar_index - 30, f_0618_long, bar_index + 10, f_0618_long, color=color.new(color.green, 50), width=1, style=line.style_dashed)
        lbl_50 := label.new(bar_index + 10, f_05_long,   "Long 0.5",   style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.lime,  size=size.tiny)
        lbl_61 := label.new(bar_index + 10, f_0618_long, "Long 0.618", style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.green, size=size.tiny)

    else if localBear and not na(f_05_short)
        l_50     := line.new(bar_index - 30, f_05_short,   bar_index + 10, f_05_short,   color=color.new(color.red,    50), width=1, style=line.style_dashed)
        l_61     := line.new(bar_index - 30, f_0618_short, bar_index + 10, f_0618_short, color=color.new(color.maroon, 50), width=1, style=line.style_dashed)
        lbl_50_s := label.new(bar_index + 10, f_05_short,   "Short 0.5",   style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.red,    size=size.tiny)
        lbl_61_s := label.new(bar_index + 10, f_0618_short, "Short 0.618", style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.maroon, size=size.tiny)

// --- Bar coloring by TMO momentum ---
barcolor(bullMom ? color.new(color.lime, 0) : bearMom ? color.new(color.red, 0) : color.new(color.gray, 60))

// ─── EXPANDED MTF DASHBOARD (6 rows) ───
var table dash = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_color=color.new(color.gray, 80), border_width=1, frame_color=color.new(color.gray, 80), frame_width=1)

if barstate.islast and i_showD
    // Row 0: HTF1 Macro Trend
    string htf1Str = htf1_bull ? "BULL ▲" : htf1_bear ? "BEAR ▼" : "NEUTRAL ◆"
    color  htf1Col = htf1_bull ? color.lime : htf1_bear ? color.red : color.gray
    table.cell(dash, 0, 0, "HTF1 (" + i_htf1 + "):", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, htf1Str,                   text_color=htf1Col,     text_size=size.small, text_halign=text.align_right)

    // Row 1: HTF2 Intermediate
    string htf2Str = htf2_bull ? "BULL ▲" : htf2_bear ? "BEAR ▼" : "NEUTRAL ◆"
    color  htf2Col = htf2_bull ? color.lime : htf2_bear ? color.red : color.gray
    table.cell(dash, 0, 1, "HTF2 (" + i_htf2 + "):", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, htf2Str,                   text_color=htf2Col,     text_size=size.small, text_halign=text.align_right)

    // Row 2: Execution TF
    string locStr = localBull ? "BULL ▲" : localBear ? "BEAR ▼" : "NEUTRAL ◆"
    color  locCol = localBull ? color.lime : localBear ? color.red : color.gray
    table.cell(dash, 0, 2, "Exec TF:",  text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, locStr,       text_color=locCol,      text_size=size.small, text_halign=text.align_right)

    // Row 3: MTF Status
    string mtfStr = mtf_bullish ? "ALIGNED BULL ✅" : mtf_bearish ? "ALIGNED BEAR ✅" : "NO ALIGN ❌"
    color  mtfCol = mtf_bullish ? color.lime : mtf_bearish ? color.red : color.orange
    table.cell(dash, 0, 3, "MTF Status:", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, mtfStr,        text_color=mtfCol,      text_size=size.small, text_halign=text.align_right)

    // Row 4: Volume Force
    string vStr = volSpike ? "HIGH 💥" : "NORMAL"
    color  vCol = volSpike ? color.yellow : color.gray
    table.cell(dash, 0, 4, "Volume Force:", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, vStr,            text_color=vCol,        text_size=size.small, text_halign=text.align_right)

    // Row 5: TMO Momentum
    string mStr = bullMom ? "UP ↑" : bearMom ? "DOWN ↓" : "FLAT —"
    color  mCol = bullMom ? color.lime : bearMom ? color.red : color.gray
    table.cell(dash, 0, 5, "TMO Mom:",  text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, mStr,         text_color=mCol,        text_size=size.small, text_halign=text.align_right)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 8 — ALERTS
// ═══════════════════════════════════════════════════════════

if isNewLong
    alert("⚡ CONFLUENCE LONG ENTRY [MTF Aligned]: " + syminfo.ticker + " | Entry: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
if isNewShort
    alert("⚡ CONFLUENCE SHORT ENTRY [MTF Aligned]: " + syminfo.ticker + " | Entry: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
