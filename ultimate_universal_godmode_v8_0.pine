// ============================================================
// ULTIMATE UNIVERSAL GOD-MODE ENGINE (v8.0)
// Advanced Confluence: 14-Factor Scoring, Adaptive ORB, SMC Breakers, Trailing SL
// ============================================================
//@version=6
indicator("Ultimate Universal God-Mode [v8.0]", overlay=true, max_boxes_count=300, max_lines_count=300, max_labels_count=300)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 1 — UNIVERSAL PRESET ENGINE (AUTO-TUNE)
// ═══════════════════════════════════════════════════════════

grp_preset = "🌎 Universal Institutional Presets"
i_mktType  = input.string("Auto Detect", "Market Preset", options=["Auto Detect", "Indices (US100/DE40)", "Metals (Gold/Silver)", "Crypto (BTC/ETH)", "Forex (Majors)", "Stocks/Custom"], group=grp_preset)

// --- Auto-Detection Matrix ---
var string mkt = i_mktType
if i_mktType == "Auto Detect"
    if str.contains(syminfo.ticker, "XAU") or str.contains(syminfo.ticker, "GOLD") or str.contains(syminfo.ticker, "XAG")
        mkt := "Metals (Gold/Silver)"
    else if str.contains(syminfo.ticker, "US100") or str.contains(syminfo.ticker, "NAS100") or str.contains(syminfo.ticker, "NDX") or str.contains(syminfo.ticker, "DAX") or str.contains(syminfo.ticker, "DE40")
        mkt := "Indices (US100/DE40)"
    else if str.contains(syminfo.ticker, "BTC") or str.contains(syminfo.ticker, "ETH") or str.contains(syminfo.ticker, "USDT") or syminfo.type == "crypto"
        mkt := "Crypto (BTC/ETH)"
    else if syminfo.type == "forex"
        mkt := "Forex (Majors)"
    else
        mkt := "Stocks/Custom"

// --- Adaptive Parameter Mapping ---
p_swing   = mkt == "Forex (Majors)" ? 5 : mkt == "Crypto (BTC/ETH)" ? 12 : 8
p_orbSess = mkt == "Indices (US100/DE40)" ? "New York (0930-1000)" : mkt == "Metals (Gold/Silver)" ? "New York (0930-1000)" : "Disabled/Crypto"
p_atrM    = mkt == "Forex (Majors)" ? 1.5 : mkt == "Crypto (BTC/ETH)" ? 3.5 : 2.5
p_reqVol  = mkt == "Crypto (BTC/ETH)" // Active volume filter for Crypto

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 2 — INPUTS
// ═══════════════════════════════════════════════════════════

grp_score = "🎯 The God-Mode Engine"
i_reqScore = input.int(7, "Min Confluence Score (1-14)", minval=1, maxval=14, step=1, group=grp_score)
i_orbSess  = input.string("Auto Detect", "ORB Session Override", options=["Auto Detect", "New York (0930-1000)", "London (0800-0830)", "Asian (2000-2030)", "Disabled/Crypto"], group=grp_score)
final_orb  = i_orbSess == "Auto Detect" ? p_orbSess : i_orbSess

grp_core  = "⚙️ Core Logic"
i_swing   = input.int(0,     "Manual Override: Swing Pts", group=grp_core)
final_sw  = i_swing == 0 ? p_swing : i_swing
i_atrLen  = input.int(14,    "ATR Length",                  group=grp_core)
i_atrM    = input.float(0.0, "ATR SL Override (0 = Auto)",  group=grp_core, step=0.1)
final_atrM = i_atrM == 0.0 ? p_atrM : i_atrM
i_tpM     = input.float(1.5, "TP R:R",                      group=grp_core, step=0.1)
i_trail   = input.bool(true, "Hull Trailing Stop",          group=grp_core)

grp_trend = "📈 Institutional Bias (MTF)"
i_tf1     = input.timeframe("240", "HTF 1 (Macro Trend)",  group=grp_trend)
i_tf2     = input.timeframe("60",  "HTF 2 (Mid-Term Trend)",group=grp_trend)
i_noRepaint= input.bool(true, "No-Repaint Bias",           group=grp_trend)

grp_ui    = "🎨 Visuals"
i_boxDist = input.int(8,     "Box Gap (bars)",              group=grp_ui)
i_boxLen  = input.int(15,    "Box Width (bars)",            group=grp_ui)
i_showD   = input.bool(true, "Show 14-Factor Matrix",      group=grp_ui)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 3 — 14-FACTOR GOD-MODE ENGINE
// ═══════════════════════════════════════════════════════════

// --- Common Tools ---
atr      = ta.atr(i_atrLen)
ema200   = ta.ema(close, 200)
baseline = ta.hma(close, 25)

// ── Factor 1: MTF Trend (4H + 1H) ──
f_get_trend(_tf) =>
    _bull = close > ta.ema(close, 200)
    _bear = close < ta.ema(close, 200)
    _resBull = i_noRepaint ? request.security(syminfo.tickerid, _tf, _bull[1], lookahead=barmerge.lookahead_off) : request.security(syminfo.tickerid, _tf, _bull)
    _resBear = i_noRepaint ? request.security(syminfo.tickerid, _tf, _bear[1], lookahead=barmerge.lookahead_off) : request.security(syminfo.tickerid, _tf, _bear)
    [_resBull, _resBear]

[tf1_bull, tf1_bear] = f_get_trend(i_tf1)
[tf2_bull, tf2_bear] = f_get_trend(i_tf2)
mtfBull = tf1_bull and tf2_bull
mtfBear = tf1_bear and tf2_bear

// ── Factor 2: Hull Baseline ──
bullHull = close > baseline
bearHull = close < baseline

// ── Factor 3: Volume Spike ──
volAvg   = ta.sma(volume, 20)
volStd   = ta.stdev(volume, 20)
volZ     = (volume - volAvg) / math.max(volStd, 0.0001)
volSpike = ta.ema(volZ, 3) > 1.2
isVolActive = volume > volAvg
bullVol = mkt == "Crypto (BTC/ETH)" ? isVolActive : volSpike
bearVol = bullVol

// ── Factor 4: TMO Momentum ──
osc      = ta.mom(ta.sma(ta.sma(close, 7), 7), 7)
bullMom  = ta.change(osc) > 0
bearMom  = ta.change(osc) < 0

// ── Factor 5: SFP / Liquidity Sweeps ──
ph = ta.pivothigh(high, final_sw, final_sw)
pl = ta.pivotlow(low,   final_sw, final_sw)
var float lastSH = na
var float lastSL = na

if not na(ph)
    lastSH := ph
if not na(pl)
    lastSL := pl

bullSweep = not na(lastSL) and low < lastSL and close > lastSL
bearSweep = not na(lastSH) and high > lastSH and close < lastSH

// ── Factor 6: Fib Golden Zone ──
diff          = math.abs(lastSH - lastSL)
midpoint      = (lastSH + lastSL) / 2
isDiscount    = close < midpoint
isPremium     = close > midpoint

// ── Factor 7: VWAP ──
bullVWAP = close > ta.vwap
bearVWAP = close < ta.vwap

// ── Factor 8: Bollinger Bands ──
bullBB = close > ta.sma(close, 20)
bearBB = close < ta.sma(close, 20)

// ── Factor 9: Daily Pivot Points ──
prevDayHigh = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
prevDayLow  = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
prevDayClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
pivotLine   = (prevDayHigh + prevDayLow + prevDayClose) / 3
bullPivot   = close > pivotLine
bearPivot   = close < pivotLine

// ── Factor 10: Fair Value Gap (FVG) ──
bullFVG = low > high[2] and close[1] > open[1]
bearFVG = high < low[2] and close[1] < open[1]

// ── Factor 11: CHoCH / MSB ──
bullMSB = ta.crossover(close, lastSH)
bearMSB = ta.crossunder(close, lastSL)

// ── Factor 12: SMC Breaker Blocks ──
var float breakerHigh = na
var float breakerLow  = na
if bullMSB
    breakerHigh := lastSH
    breakerLow  := lastSH - atr
if bearMSB
    breakerHigh := lastSL + atr
    breakerLow  := lastSL

bullBreaker = low <= breakerHigh and high >= breakerLow and close > breakerLow
bearBreaker = high >= breakerLow and low <= breakerHigh and close < breakerHigh

// ── Factor 13: ORB Breakout ──
s_time = final_orb == "New York (0930-1000)" ? "0930-1000" : final_orb == "London (0800-0830)" ? "0800-0830" : "2000-2030"
t_tz = final_orb == "New York (0930-1000)" ? "America/New_York" : final_orb == "London (0800-0830)" ? "Europe/London" : "Asia/Tokyo"
t_sess = time(timeframe.period, s_time, t_tz)
var float orbH = na
var float orbL = na
if not na(t_sess) and na(t_sess[1])
    orbH := high
    orbL := low
else if not na(t_sess)
    orbH := math.max(orbH, high)
    orbL := math.min(orbL, low)
bullORB = final_orb == "Disabled/Crypto" ? true : close > orbH
bearORB = final_orb == "Disabled/Crypto" ? true : close < orbL

// ── Factor 14: Adaptive Trend (RSI) ──
rsi      = ta.rsi(close, 14)
bullRSI  = rsi > 50
bearRSI  = rsi < 50

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 4 — SCORE & CONCURRENT SIGNALS
// ═══════════════════════════════════════════════════════════

int longPts = 0
longPts += mtfBull ? 1 : 0
longPts += bullHull ? 1 : 0
longPts += bullVol ? 1 : 0
longPts += bullMom ? 1 : 0
longPts += bullSweep ? 1 : 0
longPts += isDiscount ? 1 : 0
longPts += bullVWAP ? 1 : 0
longPts += bullBB ? 1 : 0
longPts += bullPivot ? 1 : 0
longPts += bullFVG ? 1 : 0
longPts += bullMSB ? 1 : 0
longPts += bullBreaker ? 1 : 0
longPts += bullORB ? 1 : 0
longPts += bullRSI ? 1 : 0

int shortPts = 0
shortPts += mtfBear ? 1 : 0
shortPts += bearHull ? 1 : 0
shortPts += bearVol ? 1 : 0
shortPts += bearMom ? 1 : 0
shortPts += bearSweep ? 1 : 0
shortPts += isPremium ? 1 : 0
shortPts += bearVWAP ? 1 : 0
shortPts += bearBB ? 1 : 0
shortPts += bearPivot ? 1 : 0
shortPts += bearFVG ? 1 : 0
shortPts += bearMSB ? 1 : 0
shortPts += bearBreaker ? 1 : 0
shortPts += bearORB ? 1 : 0
shortPts += bearRSI ? 1 : 0

// Signal Conditions (Must cross baseline + have score)
longCond  = (longPts >= i_reqScore)  and ta.crossover(close, baseline)
shortCond = (shortPts >= i_reqScore) and ta.crossunder(close, baseline)

// Concurrent Signals Variables
var int lastLongBar  = 0
var int lastShortBar = 0

isNewLong  = longCond  and bar_index > lastLongBar  + 10
isNewShort = shortCond and bar_index > lastShortBar + 10

if isNewLong
    lastLongBar := bar_index
if isNewShort
    lastShortBar := bar_index

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 5 — TRAILING SL & TRADE TRACKER
// ═══════════════════════════════════════════════════════════

var float trailLong = na
var float trailShort = na

if isNewLong
    trailLong := lastSL - (atr * 0.5)
if isNewShort
    trailShort := lastSH + (atr * 0.5)

// Hull Trailing Update
if i_trail and barstate.isconfirmed
    if not na(trailLong)
        trailLong := math.max(trailLong, baseline - (atr * 0.5))
        if close < trailLong
            trailLong := na
    if not na(trailShort)
        trailShort := math.min(trailShort, baseline + (atr * 0.5))
        if close > trailShort
            trailShort := na

// Signage
plotshape(isNewLong, "Long Entry", shape.triangleup, location.belowbar, color.lime, size=size.normal)
plotshape(isNewShort, "Short Entry", shape.triangledown, location.abovebar, color.red, size=size.normal)
plot(trailLong, "Long Trail", color.new(color.lime, 40), style=plot.style_linebr, linewidth=2)
plot(trailShort, "Short Trail", color.new(color.red, 40), style=plot.style_linebr, linewidth=2)

// Labels (Risk Boxes)
if isNewLong
    float dr = close - trailLong
    float tp = close + dr * i_tpM
    label.new(bar_index, low - atr, "LONG God-Mode [" + str.tostring(longPts) + "/14]\nSL: " + str.tostring(trailLong, format.mintick) + "\nTP: " + str.tostring(tp, format.mintick), style=label.style_label_up, color=color.black, textcolor=color.white, size=size.small)
    box.new(bar_index, tp, bar_index+i_boxLen, close, bgcolor=color.new(color.lime, 90), border_color=na)
    box.new(bar_index, close, bar_index+i_boxLen, trailLong, bgcolor=color.new(color.red, 90), border_color=na)

if isNewShort
    float dr = trailShort - close
    float tp = close - dr * i_tpM
    label.new(bar_index, high + atr, "SHORT God-Mode [" + str.tostring(shortPts) + "/14]\nSL: " + str.tostring(trailShort, format.mintick) + "\nTP: " + str.tostring(tp, format.mintick), style=label.style_label_down, color=color.black, textcolor=color.white, size=size.small)
    box.new(bar_index, trailShort, bar_index+i_boxLen, close, bgcolor=color.new(color.red, 90), border_color=na)
    box.new(bar_index, close, bar_index+i_boxLen, tp, bgcolor=color.new(color.lime, 90), border_color=na)

// ═══════════════════════════════════════════════════════════
// ▶ SECTION 6 — 14-FACTOR MATRIX DASHBOARD
// ═══════════════════════════════════════════════════════════

var table dash = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 85), border_color=color.new(color.gray, 80), border_width=1)

if barstate.islast and i_showD
    table.cell(dash, 0, 0, "GOD-MODE v8.0", text_color=color.white, bgcolor=color.new(color.blue, 60))
    table.cell(dash, 1, 0, mkt, text_color=color.yellow, bgcolor=color.new(color.blue, 60))
    
    table.cell(dash, 0, 1, "Long / Short", text_color=color.white)
    table.cell(dash, 1, 1, str.tostring(longPts) + " / " + str.tostring(shortPts), text_color=color.aqua)
    
    table.cell(dash, 0, 2, "Session Status", text_color=color.white)
    table.cell(dash, 1, 2, final_orb == "Disabled/Crypto" ? "Crypto Active" : not na(t_sess) ? "ORB Active" : "Wait Session", text_color=not na(t_sess) or final_orb == "Disabled/Crypto" ? color.lime : color.red)
    
    table.cell(dash, 0, 3, "Sweep / Liq", text_color=color.white)
    table.cell(dash, 1, 3, bullSweep ? "BULL SWEEP" : bearSweep ? "BEAR SWEEP" : "None", text_color=bullSweep ? color.lime : bearSweep ? color.red : color.gray)
    
    table.cell(dash, 0, 4, "SMC Breaker", text_color=color.white)
    table.cell(dash, 1, 4, bullBreaker ? "MITIGATED UP" : bearBreaker ? "MITIGATED DN" : "None", text_color=bullBreaker ? color.lime : bearBreaker ? color.red : color.gray)

    table.cell(dash, 0, 5, "FVG Status", text_color=color.white)
    table.cell(dash, 1, 5, bullFVG ? "OPEN BULL" : bearFVG ? "OPEN BEAR" : "None", text_color=bullFVG ? color.lime : bearFVG ? color.red : color.gray)

    table.cell(dash, 0, 6, "Structure (MSB)", text_color=color.white)
    table.cell(dash, 1, 6, bullMSB ? "BULL BREAK" : bearMSB ? "BEAR BREAK" : "Ranging", text_color=bullMSB ? color.lime : bearMSB ? color.red : color.gray)

    table.cell(dash, 0, 7, "Vol Filter", text_color=color.white)
    table.cell(dash, 1, 7, isVolActive ? "HIGH 💥" : "LOW", text_color=isVolActive ? color.yellow : color.gray)

// Alerts
if isNewLong
    alert("ULTIMATE LONG [v8.0]: " + syminfo.ticker + " Score: " + str.tostring(longPts), alert.freq_once_per_bar_close)
if isNewShort
    alert("ULTIMATE SHORT [v8.0]: " + syminfo.ticker + " Score: " + str.tostring(shortPts), alert.freq_once_per_bar_close)
